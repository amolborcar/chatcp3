APP_NAME="NBA Stats Assistant API"
APP_ENV="dev"
APP_HOST="0.0.0.0"
APP_PORT="8000"
API_PREFIX="/v1"

DATABASE_URL="postgresql+psycopg://postgres:postgres@localhost:5432/nba_stats"
SQL_ECHO="false"

API_KEY_HEADER="X-API-Key"
DEFAULT_LIMIT="50"
MAX_LIMIT="200"
INGEST_DEFAULT_SEASON="2024-25"
INGEST_MAX_PLAYERS="30"
INGEST_ACTIVE_ONLY="true"
